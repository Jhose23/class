import java.util.Scanner;

public class ValidarContrasena {

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        String contrasena;

        // Mostrar requisitos
        System.out.println("=== REQUISITOS DE LA CONTRASEÑA ===");
        System.out.println("- Mínimo 8 caracteres");
        System.out.println("- Debe contener al menos 1 número");
        System.out.println("- Debe contener al menos 1 letra");
        System.out.println("===================================\n");

        while (true) {
            System.out.print("Ingrese una contraseña: ");
            contrasena = sc.nextLine();

            if (esValida(contrasena)) {
                System.out.println("Contraseña válida ✅");
                break;
            } else {
                System.out.println("Contraseña inválida ❌. Intente de nuevo.\n");
            }
        }

        sc.close();
    }

    public static boolean esValida(String c) {
        if (c.length() < 8) {
            return false;
        }

        boolean tieneNumero = false;
        boolean tieneLetra = false;

        for (int i = 0; i < c.length(); i++) {
            char ch = c.charAt(i);

            if (Character.isDigit(ch)) {
                tieneNumero = true;
            }
            if (Character.isLetter(ch)) {
                tieneLetra = true;
            }
        }

        return tieneNumero && tieneLetra;
    }
}












